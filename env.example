# API Keys Configuration Template
# Copy this file to .env.local and fill in your actual API keys
# DO NOT commit .env.local to git - it's already in .gitignore

# ============================================
# AI Provider API Keys
# ============================================

# OpenAI / OpenAI-Compatible (e.g., OpenRouter, Together AI)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic / Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini / Vertex AI
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_GENERATIVE_AI_API_KEY=your_google_generative_ai_api_key_here

# Groq
GROQ_API_KEY=your_groq_api_key_here

# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key_here

# Together AI (OpenAI-compatible endpoint)
TOGETHER_API_KEY=your_together_api_key_here

# OpenRouter (OpenAI-compatible endpoint)
OPENROUTER_API_KEY=your_openrouter_api_key_here


# Cohere
COHERE_API_KEY=your_cohere_api_key_here

# ============================================
# Database & Backend
# ============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================
# Monitoring & Analytics (Optional)
# ============================================

# LangSmith / LangChain (for tracing)
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_TRACING_V2=true

# ============================================
# Other Services
# ============================================

# SerpAPI (for web search)
SERPAPI_API_KEY=your_serpapi_key_here

# Tavily (for AI search)
TAVILY_API_KEY=your_tavily_api_key_here

# Pinecone (for vector database)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment

# ============================================
# Application Settings
# ============================================

# Node Environment
NODE_ENV=development

# App URL (for callbacks, webhooks)
NEXT_PUBLIC_APP_URL=http://localhost:3000
